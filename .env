# Copy these into Coolify → your RAGFlow resource → Environment Variables.
# Do NOT commit real secrets to git. Generate strong values:
#   openssl rand -hex 24

ELASTIC_PASSWORD=77 68 61 74 65 76 65 72
MYSQL_PASSWORD=77 68 61 74 65 76 65 72
MINIO_USER=ragflow
MINIO_PASSWORD=minio
REDIS_PASSWORD=redis
TIMEZONE=Asia/Kolkata

# NOTE: Your NVIDIA NIM key is NOT set here.
# NIM (chat + embedding + rerank) is wired inside the RAGFlow web UI after
# first login — see README step 4. Keeps the key out of the compose entirely.
